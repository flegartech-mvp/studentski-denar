# Studentski Denar — environment
#
# This app is local-first and works fully offline with NO env vars set.
# Everything below is OPTIONAL and enables extra features.
#
# NOTE: every variable is VITE_-prefixed and therefore CLIENT-VISIBLE
# (bundled into the JS shipped to the browser). Only put values here that
# are safe to be public. NEVER place service-role keys or private secrets here.

# --- Optional: Supabase cloud sync / auth ---
# The "publishable"/anon key is designed to be public (RLS protects data).
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=

# --- Optional: canonical app URL used for auth redirects ---
# Falls back to window.location.origin when unset.
VITE_APP_URL=

# --- Optional: supporter/licence public key (PEM) ---
# PUBLIC verification key only (never the private signing key).
# Use literal \n for newlines. Falls back to the bundled default key.
VITE_SUPPORTER_PUBLIC_KEY_PEM=
